{
    "name": "aods/php-connector",
    "description": "AODS PHP Third-Party Service Connector",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "guzzlehttp/guzzle": "^7.8",
        "monolog/monolog": "^3.5",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "AODS\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
