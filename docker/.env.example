# AODS - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Database (Neon.tech)
# =============================================================================
DATABASE_URL=postgresql://username:password@hostname.neon.tech/aods_neural_core?sslmode=require

# =============================================================================
# Mayar Payment API
# =============================================================================
MAYAR_API_KEY=your_mayar_api_key_here
MAYAR_SANDBOX=true
MAYAR_WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# Service URLs (for local development)
# =============================================================================
API_GATEWAY_URL=http://localhost:8000
AI_SERVICE_URL=http://localhost:8001
TELEMETRY_SERVICE_URL=http://localhost:8002
CPP_HPC_URL=http://localhost:8003
CSHARP_ENTERPRISE_URL=http://localhost:8004
JAVA_BRIDGE_URL=http://localhost:8005
PHP_CONNECTOR_URL=http://localhost:8006
RUBY_AUTOMATION_URL=http://localhost:8007

# =============================================================================
# Frontend (Vercel)
# =============================================================================
VITE_API_URL=http://localhost:9000
VITE_APP_NAME=AODS
VITE_APP_VERSION=1.0.0

# =============================================================================
# Redis (for job queue)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Security
# =============================================================================
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
ENCRYPTION_KEY=your_encryption_key_here

# =============================================================================
# AI Configuration
# =============================================================================
OPENAI_API_KEY=your_openai_key_here
HUGGINGFACE_TOKEN=your_hf_token_here

# =============================================================================
# Monitoring
# =============================================================================
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_VR=true
ENABLE_AI_ASSISTANT=true
ENABLE_PAYMENTS=true
ENABLE_GAMIFICATION=true
I_ASSISTANT=true
ENABLE_PAYMENTS=true
ENABLE_GAMIFICATION=true
